# ── AI Threat Scanner — Environment Configuration ────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# OpenAI API key (sk-...)
# Can also be set via the Settings tab in the UI — that takes precedence.
OPENAI_API_KEY=sk-your-openai-key-here

# Directory for persistent JSON data (used by docker-compose bind-mount)
DATA_DIR=./backend/data
